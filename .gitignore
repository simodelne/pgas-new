# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
*.tsbuildinfo

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# IDEs
.vscode/
.idea/
*.swp

# Local dev
dist/
build/
.env
.env.local

# Stray compiled output next to TypeScript sources (typecheck script uses --noEmit;
# any .js next to a .ts is a leftover from a stray `tsc` run and will shadow the .ts
# in Node-ESM resolution via the .js import extension).
src/**/*.js
tests/**/*.js

# Claude Code session artifacts
.claude/sessions/
.claude/
.remember/
.uat/

# Foundry runtime spillover when PGAS_SESSION_LOG_DIR / PGAS_UPLOADS_DIR are
# unset (the repo-root CLI dumps session logs and upload staging into the
# working tree — bulky, transient, never committed).
session-logs/
uploads/

# SOTA harness scratch: programs synthesized during a live corpus run + live body
# caches. Transient, per-run, never committed. (tests/sota/fixtures/** IS committed —
# that is the deterministic replay fixture.)
tests/sota/generated/
tests/sota/.body-cache/

# SOTA iteration-loop scratch scorecards (keep baseline + holdout-final only)
tests/sota/scorecard/iterate-*.json
tests/sota/scorecard/iterate-*.md
tests/sota/scorecard/verify-*.json
tests/sota/scorecard/verify-*.md
tests/sota/scorecard/iter2-*.json
tests/sota/scorecard/iter2-*.md
tests/sota/scorecard/rl-*.json
tests/sota/scorecard/rl-*.md
tests/sota/scorecard/verify-closegap*.json
tests/sota/scorecard/verify-closegap*.md

# Foundry domain-synthesis cache written into cwd when run from repo root
.pgas-new-domain-synthesis-cache/
