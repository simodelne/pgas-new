{
  "name": "pgas-new",
  "version": "3.2.0",
  "private": true,
  "type": "module",
  "description": "PGAS-specific foundry for creating TypeScript/Node PGAS programs",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run --config tests/vitest.config.ts",
    "test:manifest": "bash tests/plugin-manifest.test.sh",
    "test:static": "bash tests/pgas-new-static.test.sh",
    "test": "npm run typecheck && npm run test:manifest && npm run test:unit && npm run test:static",
    "pgas-new": "node --import tsx src/cli.ts"
  },
  "bin": {
    "pgas-new": "./bin/pgas-new"
  },
  "dependencies": {
    "@simodelne/pgas-server": "^2.14.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.3",
    "js-yaml": "^4.1.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
