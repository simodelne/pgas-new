# {{CONSUMER_NAME}} — frontend env vars
#
# Copy to .env.local for local development. NEVER commit .env.local.
# Vite only exposes vars prefixed with VITE_ to client code.

# Base URL of the pgas-server REST API. Use an absolute URL when the
# backend is on a different origin, OR a relative path (e.g. "/api")
# to let the Vite dev proxy forward to localhost:8787.
VITE_PGAS_API_URL=http://localhost:8787

# WebSocket endpoint. Same rules as above.
VITE_PGAS_WS_URL=ws://localhost:8787/ws

# Auth mode the frontend should render. MUST match the value of
# PGAS_AUTH_MODE on the server (.env.local of the consumer root).
#   - dev-static-token : the login page shows a single "paste your dev
#                        token" input; the value is stashed in
#                        localStorage as the Bearer token.
#   - magic-link       : the login page shows an email input; clicking
#                        Send posts {email} to /auth/login; the user
#                        opens the link from their inbox / console; the
#                        callback page redeems the token for a JWT.
VITE_PGAS_AUTH_MODE=dev-static-token
