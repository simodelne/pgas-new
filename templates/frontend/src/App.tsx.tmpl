import { useEffect } from 'react';
import { useAuthStore } from './stores/auth';
import Login from './pages/Login';
import MagicLinkCallback from './pages/MagicLinkCallback';
import SessionList from './pages/SessionList';
import Chat from './pages/Chat';
import { Router } from './components/Router';
import { navigate } from './lib/navigate';

/**
 * {{CONSUMER_NAME}} — top-level router + auth gate.
 *
 * Auth gate: when there is no token, every route falls through to
 * <Login />. The magic-link callback (#/auth/magic/:token) is the one
 * exception — it must render even unauthenticated so the user can
 * redeem the link from the email and obtain a JWT.
 */
export default function App() {
  const token = useAuthStore((s) => s.token);
  const logout = useAuthStore((s) => s.logout);

  // Cross-tab: when the auth blob is removed in another tab,
  // mirror the sign-out here.
  useEffect(() => {
    const onStorage = (e: StorageEvent) => {
      if (e.key === 'auth' && e.newValue === null) {
        logout();
        navigate('/');
      }
    };
    window.addEventListener('storage', onStorage);
    return () => window.removeEventListener('storage', onStorage);
  }, [logout]);

  // API client emits this event on 401 — bounce back to login.
  useEffect(() => {
    const onExpired = () => {
      logout();
      navigate('/');
    };
    window.addEventListener('auth-expired', onExpired);
    return () => window.removeEventListener('auth-expired', onExpired);
  }, [logout]);

  const magicLinkRoute = {
    pattern: '/auth/magic/:token',
    render: (params: Record<string, string>) => <MagicLinkCallback token={params.token} />,
  };

  if (!token) {
    return (
      <Router
        routes={[magicLinkRoute]}
        fallback={<Login />}
      />
    );
  }

  return (
    <Router
      routes={[
        magicLinkRoute,
        { pattern: '/sessions/:id', render: (p) => <Chat sessionId={p.id} /> },
        { pattern: '/', render: () => <SessionList /> },
      ]}
      fallback={<SessionList />}
    />
  );
}
