import { useState, type FormEvent } from 'react';
import { useAuthStore } from '../stores/auth';
import { api, ApiError } from '../lib/api';

/**
 * {{CONSUMER_NAME}} — login page.
 *
 * Switches rendering on VITE_PGAS_AUTH_MODE (matches the server's
 * PGAS_AUTH_MODE):
 *   - dev-static-token : single "paste your dev token" input. The
 *                        submitted token is stashed verbatim as the
 *                        Bearer credential. There is NO server round-
 *                        trip on submit — the dev-static-token mode on
 *                        the server simply compares the Authorization
 *                        header against PGAS_DEV_STATIC_TOKEN. We
 *                        validate optimistically here and let the next
 *                        /api/sessions call surface 401 if the value is
 *                        wrong.
 *   - magic-link       : single email input. Posts {email} to
 *                        /auth/login; the server emails (or in dev,
 *                        logs) a link the user opens. The callback page
 *                        handles redemption.
 */
export default function Login() {
  const mode = import.meta.env.VITE_PGAS_AUTH_MODE || 'dev-static-token';
  return (
    <div className="min-h-screen flex items-center justify-center p-6">
      <div className="w-full max-w-md rounded-xl border border-slate-700 bg-slate-900/60 p-8 shadow-lg backdrop-blur">
        <h1 className="mb-2 text-2xl font-semibold">{`{{CONSUMER_NAME}}`}</h1>
        <p className="mb-6 text-sm text-slate-400">
          Sign in to continue. Auth mode: <code className="text-slate-300">{mode}</code>
        </p>
        {mode === 'magic-link' ? <MagicLinkForm /> : <DevTokenForm />}
      </div>
    </div>
  );
}

function DevTokenForm() {
  const login = useAuthStore((s) => s.login);
  const [token, setToken] = useState('');
  const [error, setError] = useState<string | null>(null);

  const handleSubmit = (e: FormEvent) => {
    e.preventDefault();
    setError(null);
    if (!token.trim()) {
      setError('Token is required.');
      return;
    }
    login({ token: token.trim() });
    // Land on /sessions
    window.location.hash = '#/';
  };

  return (
    <form onSubmit={handleSubmit} className="space-y-4">
      <label className="block">
        <span className="mb-1 block text-sm font-medium">Dev token</span>
        <input
          type="password"
          value={token}
          onChange={(e) => setToken(e.target.value)}
          placeholder="PGAS_DEV_STATIC_TOKEN value"
          className="w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm outline-none focus:border-blue-500"
          autoComplete="off"
        />
      </label>
      {error ? (
        <div className="rounded-md border border-red-700 bg-red-900/30 px-3 py-2 text-sm text-red-200">
          {error}
        </div>
      ) : null}
      <button
        type="submit"
        className="w-full rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-500 disabled:opacity-50"
        disabled={!token.trim()}
      >
        Continue
      </button>
      <p className="text-xs text-slate-500">
        Your token is stored in this browser's localStorage. The first
        API call surfaces a 401 if the value doesn't match the server.
      </p>
    </form>
  );
}

function MagicLinkForm() {
  const [email, setEmail] = useState('');
  const [submitted, setSubmitted] = useState(false);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState<string | null>(null);

  const handleSubmit = async (e: FormEvent) => {
    e.preventDefault();
    setError(null);
    setLoading(true);
    try {
      await api.requestMagicLink(email.trim());
      setSubmitted(true);
    } catch (err) {
      setError(err instanceof ApiError ? err.message : 'Could not request a link.');
    } finally {
      setLoading(false);
    }
  };

  const handleReset = () => {
    setSubmitted(false);
    setEmail('');
  };

  if (submitted) {
    return (
      <div className="space-y-3">
        <p className="text-sm">
          If <code className="text-slate-300">{email}</code> matches a registered user, a sign-in
          link is on its way.
        </p>
        <p className="text-xs text-slate-500">
          In dev, the server logs the magic-link URL to its console — open it from there to
          continue.
        </p>
        <button
          type="button"
          onClick={handleReset}
          className="text-sm text-blue-400 hover:text-blue-300"
        >
          Use a different email
        </button>
      </div>
    );
  }

  return (
    <form onSubmit={handleSubmit} className="space-y-4">
      <label className="block">
        <span className="mb-1 block text-sm font-medium">Email</span>
        <input
          type="email"
          value={email}
          onChange={(e) => setEmail(e.target.value)}
          required
          className="w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm outline-none focus:border-blue-500"
          autoComplete="email"
        />
      </label>
      {error ? (
        <div className="rounded-md border border-red-700 bg-red-900/30 px-3 py-2 text-sm text-red-200">
          {error}
        </div>
      ) : null}
      <button
        type="submit"
        className="w-full rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-500 disabled:opacity-50"
        disabled={!email.trim() || loading}
      >
        {loading ? 'Sending…' : 'Send sign-in link'}
      </button>
    </form>
  );
}
