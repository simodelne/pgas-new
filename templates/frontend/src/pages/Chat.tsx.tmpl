import { useEffect, useRef, useState, type FormEvent } from 'react';
import { api, ApiError } from '../lib/api';
import { useWebSocket, type WsMessage } from '../lib/ws';
import { navigate } from '../lib/navigate';

/**
 * {{CONSUMER_NAME}} — single-session chat view.
 *
 * Minimal vendored snapshot. Sends user input via POST
 * /api/sessions/:id/trigger and renders agent responses pushed via
 * the WebSocket session-event stream. This is intentionally text-only
 * — the simoneos frontend has a much richer widget framework, but the
 * v0.1 plugin scaffold ships a barebones chat so consumers can layer
 * their own widgets on top.
 */

interface ChatMessage {
  id: string;
  role: 'user' | 'agent';
  content: string;
  ts: number;
}

const DEFAULT_CHANNEL = 'user_message';

function extractAgentText(payload: unknown): string {
  // pgas-server envelopes vary; pull the first string field we
  // recognize without binding tightly to a specific schema.
  if (typeof payload === 'string') return payload;
  if (payload && typeof payload === 'object') {
    const obj = payload as Record<string, unknown>;
    for (const key of ['message', 'text', 'content', 'response', 'reply']) {
      const v = obj[key];
      if (typeof v === 'string' && v.trim()) return v;
    }
    // Sometimes the message is nested under `result` or `data`.
    for (const key of ['result', 'data']) {
      const nested = obj[key];
      if (nested) {
        const inner = extractAgentText(nested);
        if (inner) return inner;
      }
    }
  }
  return '';
}

export default function Chat({ sessionId }: { sessionId: string }) {
  const [messages, setMessages] = useState<ChatMessage[]>([]);
  const [input, setInput] = useState('');
  const [busy, setBusy] = useState(false);
  const [error, setError] = useState<string | null>(null);
  const scrollRef = useRef<HTMLDivElement>(null);

  useEffect(() => {
    if (scrollRef.current) {
      scrollRef.current.scrollTop = scrollRef.current.scrollHeight;
    }
  }, [messages.length]);

  // Listen for round_complete / session_terminal events for this
  // session and append the agent's reply.
  useWebSocket((msg: WsMessage) => {
    if (msg.sessionId !== sessionId) return;
    if (msg.type === 'round_start') {
      setBusy(true);
      return;
    }
    if (msg.type === 'round_complete' || msg.type === 'session_terminal') {
      setBusy(false);
      const content = extractAgentText(msg.data);
      if (!content) return;
      setMessages((prev) => [
        ...prev,
        {
          id: `ws-${Date.now()}-${Math.random().toString(36).slice(2, 7)}`,
          role: 'agent',
          content,
          ts: Date.now(),
        },
      ]);
    }
  });

  const handleSubmit = async (e: FormEvent) => {
    e.preventDefault();
    const text = input.trim();
    if (!text) return;
    setError(null);
    setMessages((prev) => [
      ...prev,
      {
        id: `u-${Date.now()}`,
        role: 'user',
        content: text,
        ts: Date.now(),
      },
    ]);
    setInput('');
    setBusy(true);
    try {
      await api.trigger(sessionId, DEFAULT_CHANNEL, { message: text });
    } catch (err) {
      setError(err instanceof ApiError ? err.message : 'Send failed.');
      setBusy(false);
    }
  };

  return (
    <div className="flex min-h-screen flex-col">
      <header className="border-b border-slate-800 bg-slate-900/40 px-6 py-3">
        <div className="flex items-center justify-between">
          <div>
            <button
              type="button"
              onClick={() => navigate('/')}
              className="text-xs text-blue-400 hover:text-blue-300"
            >
              ← Sessions
            </button>
            <h1 className="text-sm font-medium text-slate-300">Session {sessionId}</h1>
          </div>
        </div>
      </header>

      <div ref={scrollRef} className="flex-1 overflow-y-auto px-6 py-4">
        {messages.length === 0 ? (
          <p className="text-sm text-slate-500">No messages yet. Say something below.</p>
        ) : (
          <ul className="space-y-3">
            {messages.map((m) => (
              <li key={m.id} className={m.role === 'user' ? 'text-right' : 'text-left'}>
                <div
                  className={
                    m.role === 'user'
                      ? 'inline-block max-w-2xl rounded-lg bg-blue-600 px-3 py-2 text-sm text-white'
                      : 'inline-block max-w-2xl rounded-lg border border-slate-700 bg-slate-900/60 px-3 py-2 text-sm'
                  }
                >
                  {m.content}
                </div>
              </li>
            ))}
            {busy ? (
              <li className="text-left">
                <span className="inline-block rounded-lg border border-slate-700 bg-slate-900/60 px-3 py-2 text-sm text-slate-400">
                  Thinking…
                </span>
              </li>
            ) : null}
          </ul>
        )}
      </div>

      {error ? (
        <div className="mx-6 mb-2 rounded-md border border-red-700 bg-red-900/30 px-3 py-2 text-sm text-red-200">
          {error}
        </div>
      ) : null}

      <form onSubmit={handleSubmit} className="border-t border-slate-800 bg-slate-900/40 px-6 py-3">
        <div className="flex gap-2">
          <input
            type="text"
            value={input}
            onChange={(e) => setInput(e.target.value)}
            placeholder="Type a message…"
            className="flex-1 rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm outline-none focus:border-blue-500"
            disabled={busy}
          />
          <button
            type="submit"
            disabled={!input.trim() || busy}
            className="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-500 disabled:opacity-50"
          >
            Send
          </button>
        </div>
      </form>
    </div>
  );
}
