import { useEffect, useState } from 'react';
import { api, ApiError } from '../lib/api';
import { useAuthStore } from '../stores/auth';
import { navigate } from '../lib/navigate';

/**
 * {{CONSUMER_NAME}} — session list.
 *
 * Calls GET /api/sessions. The shape returned by pgas-server varies
 * by version; we read defensively and only display the fields all
 * known versions agree on (sessionId, program, mode, updatedAt).
 */

interface SessionRow {
  sessionId: string;
  program: string;
  mode?: string;
  status?: string;
  updatedAt?: number;
}

interface SessionsResponse {
  sessions?: SessionRow[];
}

export default function SessionList() {
  const email = useAuthStore((s) => s.email);
  const logout = useAuthStore((s) => s.logout);

  const handleSignOut = () => {
    logout();
    navigate('/');
  };

  const [sessions, setSessions] = useState<SessionRow[] | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [program, setProgram] = useState('');
  const [creating, setCreating] = useState(false);

  useEffect(() => {
    let cancelled = false;
    void (async () => {
      try {
        const res = await api.listSessions<SessionsResponse>();
        if (cancelled) return;
        setSessions(Array.isArray(res?.sessions) ? res.sessions : []);
      } catch (err) {
        if (cancelled) return;
        setError(err instanceof ApiError ? err.message : 'Could not load sessions.');
      }
    })();
    return () => {
      cancelled = true;
    };
  }, []);

  const handleCreate = async () => {
    if (!program.trim()) return;
    setCreating(true);
    try {
      const res = await api.createSession<{ sessionId?: string }>(program.trim());
      const id = res?.sessionId;
      if (id) navigate(`/sessions/${id}`);
    } catch (err) {
      setError(err instanceof ApiError ? err.message : 'Could not create session.');
    } finally {
      setCreating(false);
    }
  };

  return (
    <div className="min-h-screen p-6">
      <header className="mb-6 flex items-center justify-between">
        <div>
          <h1 className="text-2xl font-semibold">{`{{CONSUMER_NAME}}`}</h1>
          {email ? <p className="text-sm text-slate-400">Signed in as {email}</p> : null}
        </div>
        <button
          type="button"
          onClick={handleSignOut}
          className="rounded-md border border-slate-700 px-3 py-1.5 text-sm hover:bg-slate-800"
        >
          Sign out
        </button>
      </header>

      <section className="mb-6 rounded-lg border border-slate-700 bg-slate-900/40 p-4">
        <h2 className="mb-2 text-sm font-medium text-slate-300">Start a new session</h2>
        <div className="flex gap-2">
          <input
            type="text"
            value={program}
            onChange={(e) => setProgram(e.target.value)}
            placeholder="program name"
            className="flex-1 rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm outline-none focus:border-blue-500"
          />
          <button
            type="button"
            onClick={handleCreate}
            disabled={!program.trim() || creating}
            className="rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-500 disabled:opacity-50"
          >
            {creating ? 'Creating…' : 'Start'}
          </button>
        </div>
      </section>

      {error ? (
        <div className="mb-4 rounded-md border border-red-700 bg-red-900/30 px-3 py-2 text-sm text-red-200">
          {error}
        </div>
      ) : null}

      <section>
        <h2 className="mb-2 text-sm font-medium text-slate-300">Sessions</h2>
        {sessions === null ? (
          <p className="text-sm text-slate-500">Loading…</p>
        ) : sessions.length === 0 ? (
          <p className="text-sm text-slate-500">No sessions yet.</p>
        ) : (
          <ul className="divide-y divide-slate-800 rounded-lg border border-slate-700 bg-slate-900/40">
            {sessions.map((s) => (
              <li key={s.sessionId}>
                <button
                  type="button"
                  onClick={() => navigate(`/sessions/${s.sessionId}`)}
                  className="block w-full px-4 py-3 text-left hover:bg-slate-800/50"
                >
                  <div className="text-sm font-medium">{s.program}</div>
                  <div className="text-xs text-slate-500">
                    {s.sessionId} · mode {s.mode ?? '—'} · status {s.status ?? '—'}
                  </div>
                </button>
              </li>
            ))}
          </ul>
        )}
      </section>
    </div>
  );
}
