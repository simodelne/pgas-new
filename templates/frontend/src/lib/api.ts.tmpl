// Vendored from simoneos/frontend/src/api/client.ts patterns
// (snapshot 2026-06-01). Simplified: only the minimal endpoints needed
// for the {{CONSUMER_NAME}} login + session-list + chat flow. Reads
// the bearer token via lib/auth.ts and emits a window 'auth-expired'
// event on 401 so the App can route back to /login.

import { authHeader, clearAuthBlob } from './auth';

const API_BASE = import.meta.env.VITE_PGAS_API_URL || 'http://localhost:8787';

const DEFAULT_TIMEOUT_MS = 30_000;

export class ApiError extends Error {
  status: number;
  constructor(message: string, status: number) {
    super(message);
    this.status = status;
  }
}

async function request<T>(
  path: string,
  init: RequestInit & { timeoutMs?: number } = {},
): Promise<T> {
  const timeoutMs = init.timeoutMs ?? DEFAULT_TIMEOUT_MS;
  const controller = new AbortController();
  const timeoutId = window.setTimeout(() => controller.abort(), timeoutMs);

  let response: Response;
  try {
    response = await fetch(`${API_BASE}${path}`, {
      ...init,
      headers: {
        'Content-Type': 'application/json',
        ...authHeader(),
        ...(init.headers as Record<string, string> | undefined),
      },
      signal: controller.signal,
    });
  } catch (err) {
    if (err instanceof DOMException && err.name === 'AbortError') {
      throw new ApiError(`Request timed out after ${timeoutMs}ms (${path})`, 0);
    }
    if (typeof navigator !== 'undefined' && navigator.onLine === false) {
      throw new ApiError('You appear to be offline. Check your connection.', 0);
    }
    if (err instanceof TypeError && /fetch/i.test(err.message)) {
      throw new ApiError('Could not reach {{CONSUMER_NAME}}. Check your connection.', 0);
    }
    throw err;
  } finally {
    window.clearTimeout(timeoutId);
  }

  if (response.status === 401 && !path.startsWith('/auth/')) {
    clearAuthBlob();
    window.dispatchEvent(new Event('auth-expired'));
    throw new ApiError('Session expired. Please log in again.', 401);
  }

  if (!response.ok) {
    let error = `HTTP ${response.status}`;
    try {
      const body = (await response.json()) as { error?: string };
      if (body?.error) error = body.error;
    } catch {
      /* response wasn't JSON */
    }
    throw new ApiError(error, response.status);
  }

  if (response.status === 204) return {} as T;
  return (await response.json()) as T;
}

// --- Auth endpoints --------------------------------------------------------

export interface MagicLinkRedeemResponse {
  jwt: string;
  user_email: string;
  expires_at: number;
}

export const api = {
  // Magic-link mode: ask the server to email a link to the user.
  // Returns 204 on success (no body). Server intentionally does not
  // distinguish "email exists" from "email does not exist".
  requestMagicLink(email: string): Promise<void> {
    return request<void>('/auth/login', {
      method: 'POST',
      body: JSON.stringify({ email }),
    });
  },

  // Magic-link mode: redeem the single-use token from the email link
  // for a JWT.
  redeemMagicLink(token: string): Promise<MagicLinkRedeemResponse> {
    return request<MagicLinkRedeemResponse>(`/auth/magic/${encodeURIComponent(token)}`, {
      method: 'GET',
    });
  },

  // Magic-link mode: revoke the current JWT server-side.
  logout(): Promise<void> {
    return request<void>('/auth/logout', { method: 'POST' });
  },

  // --- Sessions --------------------------------------------------------
  listSessions<T = unknown>(): Promise<T> {
    return request<T>('/api/sessions');
  },

  createSession<T = unknown>(program: string): Promise<T> {
    return request<T>('/api/sessions', {
      method: 'POST',
      body: JSON.stringify({ program }),
    });
  },

  getSession<T = unknown>(sessionId: string): Promise<T> {
    return request<T>(`/api/sessions/${sessionId}`);
  },

  trigger<T = unknown>(sessionId: string, channel: string, payload: unknown): Promise<T> {
    return request<T>(`/api/sessions/${sessionId}/trigger`, {
      method: 'POST',
      body: JSON.stringify({ channel, payload }),
      timeoutMs: 120_000,
    });
  },
};
