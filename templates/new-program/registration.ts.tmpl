/**
 * {{PROGRAM_NAME}}/registration.ts
 *
 * Wiring shim for the {{PROGRAM_NAME}} program. This file contains ZERO
 * runtime logic — it only:
 *   1. loads the spec (pattern composition + $ref resolution),
 *   2. binds the program's reaction handlers,
 *   3. returns a ProgramEntry the consumer's server registers.
 *
 * Scaffolded by claude-pgas-plugin. `/pgas-new-program` injects the
 * matching `registry.register('{{PROGRAM_SLUG}}', create{{PROGRAM_NAME_PASCAL}}ProgramEntry())`
 * call into the consumer's `server/index.ts` at the
 * `[pgas-plugin:program-registration]` marker — you do NOT hand-wire it.
 *
 * Real-world references (read these when this program grows past the
 * skeleton): pgas-office `programs/email-triage/registration.ts` and
 * pgas-rag `programs/legal-rag/registration.ts`.
 */

import path from 'node:path';
import { fileURLToPath } from 'node:url';

import type { ProgramEntry } from '@simodelne/pgas-runtime-core/program-entry.js';
import { loadSpecWithPatterns } from '@simodelne/pgas-runtime-core/pattern-composer/load-with-patterns.js';
import { createProgramAdapters } from '@simodelne/pgas-runtime-core/registration-helpers.js';

import { handlers } from './handlers/index.js';

/**
 * Construct the {{PROGRAM_NAME}} ProgramEntry.
 *
 * The consumer's `server/index.ts` calls this once at boot and registers
 * the result under the slug '{{PROGRAM_SLUG}}'.
 */
export function create{{PROGRAM_NAME_PASCAL}}ProgramEntry(): ProgramEntry {
  // 1. Load the spec (pattern expansion + $ref resolution). The spec lives
  //    next to this file; resolve our own dir from import.meta.url so the
  //    path is correct no matter where the consumer runs from.
  const dirname = path.dirname(fileURLToPath(import.meta.url));
  const { spec } = loadSpecWithPatterns(path.join(dirname, 'spec.yml'));

  // 2. Assemble the ProgramEntry. createProgramAdapters maps every
  //    output channel the spec declares to the matching entry in
  //    `handlers`. The skeleton handler signature is wider than the
  //    engine's ToolHandler (it takes a ctx arg for the FM1 resolver), so
  //    we narrow with `as never` — replace this once your handlers match
  //    the `(payload) => Promise<unknown>` ToolHandler shape.
  return {
    spec,
    createAdapters: (ctx) => createProgramAdapters(spec, ctx, handlers as never),

    // -------------------------------------------------------------------
    // FM4 — handler-backed raw tool override (pgas#253 FM4). LOAD-BEARING.
    //
    // The default createAdapters above routes each `tool:<name>` channel to
    // `handlers['invoke_tool_<name>']`. If you add a raw `tool:` entry to
    // spec.yml whose call is resolved by a HANDLER (not the engine's tool
    // registry) and you do NOT override its adapter, the dispatch resolves
    // to `undefined`, the session stalls, and NO `trigger_failed` event is
    // emitted — the exact silent-stall FM4 describes.
    //
    // To close FM4 for a handler-backed raw tool, override createAdapters
    // so the tool's channel gets your custom adapter, e.g.:
    //
    //   createAdapters: (ctx) => {
    //     const adapters = createProgramAdapters(spec, ctx, handlers as never);
    //     if (spec.tools) {
    //       for (const [name, decl] of spec.tools) {
    //         if (name === 'my_raw_tool') {
    //           adapters.outputs.set(decl.channelId, {
    //             id: decl.channelId,
    //             dispatch: async (action) => {
    //               // unwrap action.payload, call your handler, return result
    //               return handlers.my_raw_tool(action as never);
    //             },
    //           });
    //         }
    //       }
    //     }
    //     return adapters;
    //   },
    //
    // THEN add the channel to syncOutContinuationPolicy.channels below, or
    // the LLM never gets a follow-up round to act on the tool result.
    // See pgas-rag `programs/legal-rag/registration.ts` (createSubmitGenerateAdapter
    // + the spec.tools loop) and pgas-office `programs/email-triage/registration.ts`
    // (the tool:<name> overlay) for the canonical worked examples.
    // -------------------------------------------------------------------

    // -------------------------------------------------------------------
    // Optional program-level policies. Uncomment + fill in as the program
    // grows. These are documentation pointers, NOT dead code — delete the
    // block if your program never needs the policy.
    //
    // continuationPolicy: drive auto-continuation across mode entries and
    //   notice terminals. See pgas-rag registration.ts (modeEntryAutoContinue
    //   + noticeAutoContinue) and pgas-office registration.ts (adds autoStart).
    // continuationPolicy: { modeEntryAutoContinue: true, noticeAutoContinue: true },
    //
    // syncOutContinuationPolicy: list every sync-out / handler-backed tool
    //   channel that must round-trip a result back to the LLM. REQUIRED
    //   alongside any FM4 override above. See pgas-rag registration.ts
    //   (channels: ['tool:document_search', ...]).
    // syncOutContinuationPolicy: { channels: [] },
    //
    // queryPolicy: restrict which world-state prefixes the LLM may
    //   query_state. See pgas-rag registration.ts (ALLOWED_QUERY_PREFIXES).
    // queryPolicy: { allowedWorldQueryPrefixes: [], mode: 'enforce' },
    //
    // manifest: required for a router-fronted consumer to route to this
    //   program. See pgas-rag/pgas-office registration.ts (manifest block).
    // manifest: { description: '{{PROGRAM_NAME}} program.', keywords: ['{{PROGRAM_SLUG}}'], interactive: true },
    // -------------------------------------------------------------------
  };
}
