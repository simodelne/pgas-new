 * programs/{{PROGRAM_SLUG}}/tests/spec-load.test.ts
 *
 * Born-with-tests pair (1 of 2): the spec contract test.
 *
 * Scaffolded by claude-pgas-plugin. Asserts the minimal invariants that
 * keep a program loadable and FM5-safe:
 *   - spec.yml loads cleanly through the pattern composer
 *   - spec.name matches this program's slug
 *   - the engine-owned `inputs.query_meta.*` / `inputs.query_result.*` /
 *     `inputs.mode_entry.*` FM5 paths are declared (without these the
 *     v1.8.x sync-out replay envelope is rejected — see pgas#253 FM5)
 *   - the initial + terminal modes exist in the modes map
 *
 * This file mirrors the STRUCTURE of a real consumer's spec test
 * (pgas-office programs/email-triage/tests/spec-loads.test.ts), minimized
 * to the shape every scaffolded program shares. Extend it with your
 * program-specific assertions (action_map contents, channel wiring,
 * forbidden verbs, reaction names) as you build out the spec.
 *
 * Vitest picks this up via its default include glob (it matches
 * `*.test.ts` at any depth, excluding node_modules + dist), so no
 * consumer-level vitest config is required — `npm test` (`vitest run`)
 * finds it automatically.
 */

import path from 'node:path';
import { fileURLToPath } from 'node:url';
import { describe, expect, it } from 'vitest';
import { loadSpecWithPatterns } from '@simodelne/pgas-runtime-core/pattern-composer/load-with-patterns.js';

const SPEC_PATH = path.resolve(
  path.dirname(fileURLToPath(import.meta.url)),
  '..',
  'spec.yml',
);

describe('{{PROGRAM_SLUG}} spec', () => {
  it('loads cleanly through the pattern composer', () => {
    expect(() => loadSpecWithPatterns(SPEC_PATH)).not.toThrow();
  });

  it('exposes the expected program name', () => {
    const { spec } = loadSpecWithPatterns(SPEC_PATH);
    expect(spec.name).toBe('{{PROGRAM_SLUG}}');
  });

  it('declares the engine-owned FM5 continuation paths in its schema', () => {
    const { spec } = loadSpecWithPatterns(SPEC_PATH);
    // The loaded spec exposes `schema` as a Map of dotted-path → type.
    const schemaKeys = new Set([...spec.schema.keys()]);
    // pgas#253 FM5: the v1.8.x sync-out replay envelope flattens these
    // engine-owned leaves into the channel payload. If they are not
    // schema-declared, validateChannelEvent rejects the replay with
    // `ClientInputError: Payload path "..." is not schema-declared`.
    for (const enginePath of [
      'inputs.query_meta.source_path',
      'inputs.query_meta.message',
      'inputs.query_result.kind',
      'inputs.mode_entry.mode',
    ]) {
      expect(
        schemaKeys.has(enginePath),
        `schema must declare engine-owned FM5 path ${enginePath}`,
      ).toBe(true);
    }
  });

  it('has its initial + terminal modes present in the modes map', () => {
    const { spec } = loadSpecWithPatterns(SPEC_PATH);
    const modeNames = new Set([...spec.modes.keys()]);
    expect(modeNames.has(spec.initial)).toBe(true);
    // `terminal` is a list of mode names; every terminal mode must exist.
    for (const terminalMode of spec.terminal ?? []) {
      expect(
        modeNames.has(terminalMode),
        `terminal mode ${terminalMode} must exist in the modes map`,
      ).toBe(true);
    }
    expect((spec.terminal ?? []).length).toBeGreaterThan(0);
  });
});
