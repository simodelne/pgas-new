import { describe, expect, it } from 'vitest';
import { create{{PROGRAM_NAME_PASCAL}}ProgramEntry } from '../registration.js';

describe('{{PROGRAM_SLUG}} createProgramEntry', () => {
  it('returns a ProgramEntry carrying a spec with the expected name', () => {
    const entry = create{{PROGRAM_NAME_PASCAL}}ProgramEntry();
    expect(entry.spec).toBeDefined();
    expect(entry.spec.name).toBe('{{PROGRAM_SLUG}}');
  });

  it('exposes a callable createAdapters factory', () => {
    const entry = create{{PROGRAM_NAME_PASCAL}}ProgramEntry();
    expect(typeof entry.createAdapters).toBe('function');
  });
});
