import { resolveDomainPath, type DomainSnapshot } from './_resolver.js';

/**
 * THE ENGINE'S REAL CALLING CONVENTION (verified against
 * pgas-runtime-core registration-helpers.ts `createServerOutputAdapter`):
 *
 *   handlers[action](payload)   // ONE argument — there is no ctx param
 *
 * The engine injects the world snapshot INTO the payload at
 * `payload.domain`, as a PLAIN OBJECT keyed by flat dotted paths.
 * A two-arg `(payload, ctx)` handler crashes at runtime with
 * `Cannot read properties of undefined (reading 'domain')` — tsc
 * cannot catch it (the registry is widened at the adapter boundary).
 * The plugin's program-smoke gate exercises this for real.
 */

/**
 * example_action — your first action handler.
 *
 * The mutation is declared in spec.yml's action_map; this handler is
 * called for any side effect beyond the declarative mutation.
 *
 * Currently this is a no-op skeleton; your real implementation goes
 * here. The FM1 pattern is shown for illustration.
 */
export async function example_action(
  payload: Record<string, unknown>,
): Promise<void> {
  // The engine-injected domain snapshot (plain object, flat dotted keys).
  const domain = (payload.domain ?? {}) as DomainSnapshot;

  // FM1 pattern: read engine-managed fields via the resolver, not
  // directly from payload. Even though `reasoning` is an explicit arg
  // here, the same pattern applies to ANY field that might be
  // server-owned (work.*, inputs.*, decisions.*).
  const reasoning = resolveDomainPath(payload, domain, 'work.example');

  // For required fields, use requireDomainPath (from './_resolver.js')
  // — it throws clearly instead of silently undefining:
  //   const userIntent = requireDomainPath<string>(payload, domain, 'inputs.answers.user_intent');

  // Your real work goes here. Pure logging skeleton:
  console.log('[{{PROGRAM_NAME}}] example_action invoked, reasoning =', reasoning);
}

/**
 * Handler registry — exported for the consumer's
 * createProgramAdapters or createDeclarativeSession wiring.
 */
export const handlers = {
  example_action,
};
