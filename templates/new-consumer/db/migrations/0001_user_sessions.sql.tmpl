-- {{CONSUMER_NAME}} — user_sessions table (plugin v0.2, Brief 2).
--
-- Tracks every issued JWT by its `jti`. Revoking a session = writing
-- `revoked_at`. The auth middleware checks `revoked_at IS NULL` AND
-- `expires_at > now()` before admitting a request.
--
-- Run via your consumer's migration runner before the server starts
-- accepting auth-protected requests.

CREATE TABLE IF NOT EXISTS user_sessions (
  id          INTEGER PRIMARY KEY AUTOINCREMENT,
  user_email  TEXT    NOT NULL,
  jti         TEXT    NOT NULL UNIQUE,
  created_at  INTEGER NOT NULL,
  expires_at  INTEGER NOT NULL,
  revoked_at  INTEGER
);

CREATE INDEX IF NOT EXISTS idx_user_sessions_jti ON user_sessions (jti);
