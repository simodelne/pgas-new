/**
 * {{CONSUMER_NAME}} — auth routes (Hono).
 *
 *   POST /auth/login         — issue a magic link to the supplied email
 *                              (magic-link mode only; 404 in dev-static-token).
 *   GET  /auth/magic/:token  — redeem a magic-link token; returns a JWT.
 *   POST /auth/logout        — revoke the caller's session (requires Bearer).
 *
 * The routes are PUBLIC (no `authMiddleware` mounted on them) — mounting
 * the middleware on `/auth/*` would chicken-and-egg the login flow.
 *
 * TODO(rate-limiting): production deploys MUST rate-limit /auth/login —
 * out of scope for v0.1. Bolt on `hono-rate-limiter` or a reverse-proxy
 * rule before deploying to a public network.
 */

import { Hono } from 'hono';
import { authConfig } from './config.js';
import { issueMagicLink, redeemMagicLink, revokeSessionByJti } from './magic-link.js';
import { verifyJwt } from './jwt.js';
import type { AuthContext } from './types.js';

export const authRoutes = new Hono<AuthContext>();

// POST /auth/login { email } → 204 (don't leak existence of accounts)
authRoutes.post('/login', async (c) => {
  if (authConfig.mode !== 'magic-link') {
    // dev-static-token has no /login flow; surface 404 so clients don't
    // accidentally rely on it.
    return c.json({ error: 'not_found' }, 404);
  }

  let body: unknown;
  try {
    body = await c.req.json();
  } catch {
    return c.json({ error: 'bad_request' }, 400);
  }
  const email =
    body && typeof body === 'object' && 'email' in body && typeof body.email === 'string'
      ? body.email.trim().toLowerCase()
      : null;
  if (!email || !email.includes('@')) {
    return c.json({ error: 'bad_request' }, 400);
  }

  const { token, expiresAt } = issueMagicLink(email);
  const origin = c.req.header('origin') ?? `http://localhost:${process.env.SERVER_PORT ?? '8787'}`;
  const url = `${origin}/auth/magic/${token}`;
  await authConfig.onMagicLink(email, url);

  // Always 204 regardless of whether the email exists in any user table.
  // We deliberately do not expose "user found" vs "user not found".
  return c.body(null, 204, { 'x-magic-link-expires-at': String(expiresAt) });
});

// GET /auth/magic/:token → { jwt, expires_at }
authRoutes.get('/magic/:token', async (c) => {
  if (authConfig.mode !== 'magic-link') {
    return c.json({ error: 'not_found' }, 404);
  }
  const token = c.req.param('token');
  if (!token) return c.json({ error: 'bad_request' }, 400);
  const result = await redeemMagicLink(token);
  if (!result) return c.json({ error: 'invalid_or_expired' }, 400);
  return c.json({
    jwt: result.jwt,
    user_email: result.userEmail,
    expires_at: result.expiresAt,
  });
});

// POST /auth/logout → 204. Requires Bearer; revokes the session it identifies.
authRoutes.post('/logout', async (c) => {
  if (authConfig.mode !== 'magic-link') {
    // dev-static-token can't be revoked from a request (it's a single shared
    // secret). 204 anyway so clients can drop their local token uniformly.
    return c.body(null, 204);
  }
  const header = c.req.header('authorization') ?? c.req.header('Authorization');
  const m = header ? /^Bearer\s+(.+)$/.exec(header) : null;
  const token = m ? m[1].trim() : null;
  if (!token) return c.json({ error: 'unauthorized' }, 401);
  const claims = await verifyJwt(token);
  if (!claims) return c.json({ error: 'unauthorized' }, 401);
  revokeSessionByJti(claims.jti);
  return c.body(null, 204);
});
