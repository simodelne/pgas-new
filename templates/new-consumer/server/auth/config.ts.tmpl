/**
 * {{CONSUMER_NAME}} — auth config + seams.
 *
 * This is the SINGLE place a consumer wires their email provider for the
 * magic-link flow. The default `onMagicLink` impl logs to console — fine
 * for dev, NOT fine for production.
 *
 * To plug in a real email provider (SendGrid, Postmark, SES, etc.):
 *
 *   import { authConfig } from './config.js';
 *   authConfig.onMagicLink = async (email, url) => {
 *     await myMailer.send({ to: email, subject: 'Sign in', text: url });
 *   };
 *
 * Do this once at server bootstrap (before `app.route('/auth', authRoutes)`).
 */

import type { AuthMode } from './types.js';

export interface AuthConfig {
  /** Selected at startup from `PGAS_AUTH_MODE`. */
  mode: AuthMode;
  /** Session TTL in seconds. Default 30 days. From `PGAS_SESSION_TTL_SECONDS`. */
  sessionTtlSeconds: number;
  /** Magic-link TTL in seconds. Default 10 minutes. From `PGAS_MAGIC_LINK_TTL_SECONDS`. */
  magicLinkTtlSeconds: number;
  /**
   * Called when a magic link is issued. Default: logs the URL to console.
   *
   * PRODUCTION: replace this with your email-send. The plugin v0.1 does NOT
   * integrate an email provider — that's a consumer-level wiring decision.
   */
  onMagicLink: (email: string, url: string) => void | Promise<void>;
}

function readMode(): AuthMode {
  const raw = process.env.PGAS_AUTH_MODE ?? 'dev-static-token';
  if (raw === 'dev-static-token' || raw === 'magic-link') return raw;
  throw new Error(
    `PGAS_AUTH_MODE=${raw} is not a recognised auth mode. Use 'dev-static-token' or 'magic-link'.`,
  );
}

function readPositiveInt(name: string, fallback: number): number {
  const raw = process.env[name];
  if (!raw) return fallback;
  const n = Number(raw);
  if (!Number.isFinite(n) || n <= 0) {
    throw new Error(`${name}=${raw} is not a positive integer.`);
  }
  return Math.floor(n);
}

export const authConfig: AuthConfig = {
  mode: readMode(),
  sessionTtlSeconds: readPositiveInt('PGAS_SESSION_TTL_SECONDS', 30 * 24 * 60 * 60),
  magicLinkTtlSeconds: readPositiveInt('PGAS_MAGIC_LINK_TTL_SECONDS', 10 * 60),
  // PRODUCTION: replace console.log with email-send via your provider.
  onMagicLink: (email, url) => {
    // eslint-disable-next-line no-console
    console.log(`[auth] magic-link issued for ${email}: ${url}`);
  },
};
