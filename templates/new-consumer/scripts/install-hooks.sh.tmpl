#!/usr/bin/env bash
# install-hooks.sh — idempotent pre-commit hook installer for {{CONSUMER_NAME}}
#
# Installs a pre-commit hook that runs the plugin's spec-validate
# + mode-entry-lint skills on staged *spec.yml files.

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

HOOK_PATH=".git/hooks/pre-commit"
mkdir -p "$(dirname "$HOOK_PATH")"

cat > "$HOOK_PATH" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

# Run spec validation on every staged *spec.yml
STAGED=$(git diff --cached --name-only | grep -E '(^|/)(spec|specs)\.ya?ml$' || true)
if [[ -n "$STAGED" ]]; then
  for spec in $STAGED; do
    [[ -f "$spec" ]] || continue
    echo "[pre-commit] validating $spec"
    node --input-type=module -e "
      import('@simodelne/pgas-runtime').then(async (m) => {
        try { await m.loadSpec('$spec'); process.exit(0); }
        catch (e) { console.error('  ' + e.message); process.exit(1); }
      });
    " || {
      echo "[pre-commit] FAIL: $spec failed loadSpec()."
      echo "             Run /pgas:spec-validate for details."
      echo "             To bypass (NOT RECOMMENDED): git commit --no-verify"
      exit 1
    }
  done
fi
EOF

chmod +x "$HOOK_PATH"
echo "[install-hooks] installed $HOOK_PATH"
