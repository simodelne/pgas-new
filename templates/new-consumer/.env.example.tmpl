# {{CONSUMER_NAME}} — environment variables
#
# Copy this file to .env.local for local development. NEVER commit
# .env.local. The .gitignore already excludes it; double-check before
# any push.

# GitHub Packages — for `npm install` of @simodelne/pgas-*.
# Generate a fine-grained PAT with read:packages on simodelne.
NPM_TOKEN=ghp_REPLACE_ME

# Server
SERVER_PORT=8787

# Default LLM provider — one of: ollama, gemini, openai
# (Brief 2 / 3 may add more.)
PGAS_PROVIDER=ollama

# Auth — see server/auth/ + docs/secrets-manifest.md
# Two modes are supported. Pick one:
#   - dev-static-token (default): zero-friction. Single shared bearer token.
#   - magic-link: email-issued single-use token redeemed for a JWT.
PGAS_AUTH_MODE=dev-static-token            # dev-static-token | magic-link

# REQUIRED in PGAS_AUTH_MODE=magic-link. Generate with:
#   openssl rand -hex 32
# Rotating this value invalidates EVERY outstanding JWT.
PGAS_JWT_SECRET=                           # 32+ random bytes

# REQUIRED in PGAS_AUTH_MODE=dev-static-token. Any string works;
# clients must send `Authorization: Bearer <this value>`.
PGAS_DEV_STATIC_TOKEN=                     # any string

# Session JWT lifetime (magic-link mode). Default 30 days.
PGAS_SESSION_TTL_SECONDS=2592000

# Magic-link redeem window. Default 10 minutes.
PGAS_MAGIC_LINK_TTL_SECONDS=600

# Optional: provider API keys (only set the ones you use)
# GEMINI_API_KEY=
# OPENAI_API_KEY=
