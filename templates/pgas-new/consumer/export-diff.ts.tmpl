export type DiffToken = { op: 'eq' | 'ins' | 'del'; text: string };

export function diffTokens(original: string, accepted: string): DiffToken[] {
  const left = words(original);
  const right = words(accepted);
  const table = lcsTable(left, right);
  const output: DiffToken[] = [];
  let i = 0;
  let j = 0;

  while (i < left.length && j < right.length) {
    if (left[i] === right[j]) {
      output.push({ op: 'eq', text: left[i]! });
      i += 1;
      j += 1;
    } else if (table[i + 1]![j]! >= table[i]![j + 1]!) {
      output.push({ op: 'del', text: left[i]! });
      i += 1;
    } else {
      output.push({ op: 'ins', text: right[j]! });
      j += 1;
    }
  }

  while (i < left.length) {
    output.push({ op: 'del', text: left[i]! });
    i += 1;
  }
  while (j < right.length) {
    output.push({ op: 'ins', text: right[j]! });
    j += 1;
  }

  return output;
}

function words(value: string): string[] {
  const trimmed = value.trim();
  return trimmed.length === 0 ? [] : trimmed.split(/\s+/u);
}

function lcsTable(left: string[], right: string[]): number[][] {
  const rows = left.length + 1;
  const cols = right.length + 1;
  const table = Array.from({ length: rows }, () => Array.from({ length: cols }, () => 0));

  for (let i = left.length - 1; i >= 0; i -= 1) {
    for (let j = right.length - 1; j >= 0; j -= 1) {
      table[i]![j] = left[i] === right[j]
        ? table[i + 1]![j + 1]! + 1
        : Math.max(table[i + 1]![j]!, table[i]![j + 1]!);
    }
  }

  return table;
}
