export interface ProgramDocumentInput {
  title?: string;
  clientName?: string;
  serviceType?: string;
  jurisdiction?: string;
  currency?: string;
  executiveSummary?: string;
  scope?: string[];
  deliverables?: string[];
  assumptions?: string[];
  exclusions?: string[];
  dependencies?: string[];
  changeControl?: string;
  pricingOptions?: Array<{ label: string; amount: number; detail?: string }>;
  recommendedOption?: string;
  pricingRationale?: string;
  paymentTerms?: string;
  validity?: string;
  signaturePage?: string;
}

export function renderHtmlDocument(body: string): string {
  return documentShell(body);
}

export function renderStructuredHtmlDocument(input: ProgramDocumentInput): string {
  const currency = input.currency ?? 'USD';
  return documentShell([
    `<section class="hero"><p class="eyebrow">Professional fee proposal</p><h1>${escapeHtml(input.title ?? '{{NAME}}')}</h1><p>${escapeHtml(input.executiveSummary ?? 'Prepared for client review and approval.')}</p></section>`,
    metadataTable([
      ['Client', input.clientName ?? 'Client'],
      ['Service', input.serviceType ?? 'Professional services'],
      ['Jurisdiction', input.jurisdiction ?? 'To be confirmed'],
      ['Currency', currency],
    ]),
    section('Scope of Work', list(input.scope ?? [])),
    section('Deliverables', list(input.deliverables ?? [])),
    pricingTable(input.pricingOptions ?? [], currency),
    section('Recommended Option', `<p>${escapeHtml(input.recommendedOption ?? 'To be selected')}</p><p>${escapeHtml(input.pricingRationale ?? '')}</p>`),
    section('Assumptions', list(input.assumptions ?? [])),
    section('Exclusions', list(input.exclusions ?? [])),
    section('Client Dependencies', list(input.dependencies ?? [])),
    section('Commercial Terms', [
      `<p><strong>Payment terms:</strong> ${escapeHtml(input.paymentTerms ?? 'To be agreed in writing.')}</p>`,
      `<p><strong>Validity:</strong> ${escapeHtml(input.validity ?? 'This proposal remains open for acceptance for 30 days unless withdrawn earlier.')}</p>`,
      `<p><strong>Change control:</strong> ${escapeHtml(input.changeControl ?? 'Out-of-scope work requires written approval before commencement.')}</p>`,
    ].join('')),
    signatureSection(input.signaturePage),
  ].join('\n'));
}

function documentShell(body: string): string {
  return [
    '<!doctype html>',
    '<html lang="en">',
    '<head>',
    '<meta charset="utf-8">',
    '<meta name="viewport" content="width=device-width, initial-scale=1">',
    '<title>{{NAME}}</title>',
    '<style>',
    ':root{color:#171717;background:#f7f7f4;font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;}',
    'body{margin:0;padding:32px;background:#f7f7f4;color:#171717;}',
    'main{max-width:920px;margin:0 auto;background:#fff;border:1px solid #d9d8d2;padding:44px;}',
    '.hero{border-bottom:3px solid #1f4d3a;padding-bottom:22px;margin-bottom:28px;}',
    '.eyebrow{text-transform:uppercase;font-size:12px;letter-spacing:.08em;color:#496057;margin:0 0 10px;}',
    'h1{font-size:34px;line-height:1.12;margin:0 0 10px;}',
    'h2{font-size:20px;margin:30px 0 10px;color:#1f4d3a;}',
    'p,li,td,th{font-size:14px;line-height:1.55;}',
    'table{width:100%;border-collapse:collapse;margin:12px 0 22px;}',
    'th,td{border:1px solid #d9d8d2;padding:10px;text-align:left;vertical-align:top;}',
    'th{background:#eef3f0;color:#1f4d3a;}',
    '.signature-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:26px;}',
    '.signature-line{border-top:1px solid #555;padding-top:8px;min-height:44px;}',
    '@media print{body{background:#fff;padding:0;}main{border:0;max-width:none;}}',
    '</style>',
    '</head>',
    '<body><main>',
    body,
    '</main></body></html>',
  ].join('\n');
}

function metadataTable(rows: Array<[string, string]>): string {
  return `<table><tbody>${rows.map(([label, value]) => `<tr><th>${escapeHtml(label)}</th><td>${escapeHtml(value)}</td></tr>`).join('')}</tbody></table>`;
}

function section(title: string, body: string): string {
  return `<section><h2>${escapeHtml(title)}</h2>${body || '<p>Pending.</p>'}</section>`;
}

function list(items: string[]): string {
  const clean = items.map((item) => item.trim()).filter(Boolean);
  if (clean.length === 0) return '<p>Pending.</p>';
  return `<ul>${clean.map((item) => `<li>${escapeHtml(item)}</li>`).join('')}</ul>`;
}

function pricingTable(options: Array<{ label: string; amount: number; detail?: string }>, currency: string): string {
  const rows = options.length > 0 ? options : [{ label: 'Fee proposal', amount: 0, detail: 'Pending fee model approval.' }];
  return section('Fee Options', `<table><thead><tr><th>Option</th><th>Fee</th><th>Notes</th></tr></thead><tbody>${rows.map((option) => `<tr><td>${escapeHtml(option.label)}</td><td>${escapeHtml(formatMoney(option.amount, currency))}</td><td>${escapeHtml(option.detail ?? '')}</td></tr>`).join('')}</tbody></table>`);
}

function signatureSection(signaturePage: string | undefined): string {
  if (signaturePage && signaturePage.trim().length > 0) {
    return section('Acceptance and Signature', `<p>${escapeHtml(signaturePage)}</p>`);
  }
  return section('Acceptance and Signature', [
    '<div class="signature-grid">',
    '<div class="signature-line">Client authorized signatory</div>',
    '<div class="signature-line">Date</div>',
    '</div>',
  ].join(''));
}

function formatMoney(value: number, currency: string): string {
  if (!Number.isFinite(value) || value <= 0) return 'To be confirmed';
  return `${currency} ${Math.round(value).toLocaleString('en-US')}`;
}

function escapeHtml(value: string): string {
  return value
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#39;');
}
