name: "{{SLUG}}"
termination: BoundedSession
topology: CyclicTopology
pure: true

preamble: |
  Program: {{NAME}}. You create PGAS programs through governed modes,
  explicit artifact planning, repo-curator wiring manifests, and static
  then live verification. Use only the current mode vocabulary and keep
  user decisions in the notebook-backed domain.

initial: intake_intelligence
terminal: [pr_graduation]

features:
  - base
  - runtime_control

channels:
  user_text: { direction: In, sync: Async }
  widget_output: { direction: Out, sync: Async }

modes:
  intake_intelligence:
    vocabulary: [record_user_note, pin_notebook_note, web_research, session_new, session_abort_current, session_status, session_history, session_resume, session_help]
    channels: [user_text, widget_output]
    transitions:
      - target: repo_targeting
        guard: { kind: FieldTruthy, path: intake.mandate }
  repo_targeting:
    vocabulary: [select_repo_target, authorize_standalone_target, load_wiring_manifest, authorize_existing_repo_target, create_curator_request, session_new, session_abort_current, session_status, session_history, session_resume, session_help]
    channels: [widget_output]
    preconditions:
      authorize_standalone_target:
        - { kind: FieldEquals, path: repo.target_kind, value: standalone_repo }
      load_wiring_manifest:
        - { kind: FieldEquals, path: repo.target_kind, value: existing_repo }
      authorize_existing_repo_target:
        - { kind: FieldEquals, path: repo.target_kind, value: existing_repo }
        - { kind: FieldEquals, path: repo.wiring_manifest.status, value: valid }
        - { kind: FieldEquals, path: repo.wiring_manifest.path, value: .pgas/wiring.yml }
    transitions:
      - target: architecture_design
        guard: { kind: FieldTruthy, path: repo.write_authorized }
      - target: curator_request
        guard: { kind: FieldTruthy, path: repo.blocked }
  architecture_design:
    vocabulary: [design_architecture, record_user_note, web_research, session_new, session_abort_current, session_status, session_history, session_resume, session_help]
    channels: [widget_output]
    transitions:
      - target: scaffold_plan
        guard: { kind: FieldTruthy, path: program.architecture_ready }
  scaffold_plan:
    vocabulary: [plan_artifacts, approve_artifact_plan, create_curator_request, session_new, session_abort_current, session_status, session_history, session_resume, session_help]
    channels: [widget_output]
    preconditions:
      approve_artifact_plan:
        - { kind: FieldTruthy, path: repo.write_authorized }
    transitions:
      - target: branch_write
        guard: { kind: FieldTruthy, path: artifact_plan.write_authorized }
  branch_write:
    vocabulary: [write_scaffold_artifacts, git_status, session_new, session_abort_current, session_status, session_history, session_resume, session_help]
    channels: [widget_output]
    preconditions:
      write_scaffold_artifacts:
        - { kind: FieldTruthy, path: artifact_plan.write_authorized }
    transitions:
      - target: static_verify
        guard: { kind: FieldTruthy, path: artifacts.written }
  static_verify:
    vocabulary: [npm_install, npm_typecheck, npm_test, run_static_verification, session_new, session_abort_current, session_status, session_history, session_resume, session_help]
    channels: [widget_output]
    transitions:
      - target: live_verify
        guard: { kind: FieldEquals, path: graduation.static_verification, value: passed }
  live_verify:
    vocabulary: [run_api_blackbox_verification, run_live_provider_verification, session_new, session_abort_current, session_status, session_history, session_resume, session_help]
    channels: [widget_output]
    transitions:
      - target: rebase_verify
        guard: { kind: FieldEquals, path: graduation.live_verification, value: passed }
  rebase_verify:
    vocabulary: [git_status, git_rebase_latest, run_rebase_static_verification, session_new, session_abort_current, session_status, session_history, session_resume, session_help]
    channels: [widget_output]
    preconditions:
      run_rebase_static_verification:
        - { kind: FieldEquals, path: graduation.rebase_status, value: passed }
    transitions:
      - target: pr_graduation
        guard: { kind: FieldEquals, path: graduation.rebase_verification, value: passed }
  pr_graduation:
    vocabulary: [open_pull_request, session_new, session_abort_current, session_status, session_history, session_resume, session_help]
    channels: [widget_output]
  curator_request:
    vocabulary: [create_curator_request, record_user_note, session_new, session_abort_current, session_status, session_history, session_resume, session_help]
    channels: [widget_output]
    transitions:
      - target: repo_targeting
        guard: { kind: FieldTruthy, path: repo.curator_request_lodged }

proceed_to:
  authorize_standalone_target: architecture_design
  authorize_existing_repo_target: architecture_design
  design_architecture: scaffold_plan
  approve_artifact_plan: branch_write
  write_scaffold_artifacts: static_verify
  run_static_verification: live_verify
  run_live_provider_verification: rebase_verify
  run_rebase_static_verification: pr_graduation

projection:
  intake_intelligence:
    include: [intake.mandate, notebook.entries, notebook.pins]
    exclude: []
  repo_targeting:
    include: [repo.target_kind, repo.wiring_manifest.status, repo.wiring_manifest.path, repo.write_authorized, repo.required_facilities_missing]
    exclude: []
  architecture_design:
    include: [program.slug, program.runtime, program.architecture_ready]
    exclude: []
  scaffold_plan:
    include: [artifact_plan.status, artifact_plan.approved, artifact_plan.write_authorized]
    exclude: []
  branch_write:
    include: [artifacts.written, artifacts.generated_paths]
    exclude: []
  static_verify:
    include: [graduation.static_verification, graduation.static_evidence_id]
    exclude: []
  live_verify:
    include: [graduation.live_verification, graduation.live_provider_intent, graduation.live_evidence_id]
    exclude: []
  rebase_verify:
    include: [graduation.rebase_status, graduation.rebase_evidence_id, graduation.rebase_verification, graduation.rebase_static_evidence_id]
    exclude: []
  curator_request:
    include: [repo.curator_request_lodged, repo.required_facilities_missing]
    exclude: []

prompts:
  intake_intelligence: "Capture mandate, notebook notes, and confirmed research scope."
  repo_targeting: "Validate target mode and fixed .pgas/wiring.yml if attaching to an existing repo."
  architecture_design: "Design the PGAS-specific program and attachment points."
  scaffold_plan: "Create and approve the artifact plan before writes."
  branch_write: "Write only planned artifacts."
  static_verify: "Run static verification and record evidence."
  live_verify: "Run real-provider verification through the external API."
  rebase_verify: "Rebase on latest target repo state and rerun static verification."
  pr_graduation: "Open the PR after post-rebase verification."
  curator_request: "Prepare a curator request for missing repo wiring."

ingestion:
  user_text: [intake.mandate]

action_map:
  record_user_note: { description: "Record a notebook note.", mutations: [{ op: MAppend, path: notebook.entries, from_arg: note }], channel: widget_output }
  pin_notebook_note: { description: "Pin a notebook note for next-turn projection.", mutations: [{ op: MAppend, path: notebook.pins, from_arg: key }], channel: widget_output }
  web_research: { description: "Run user-confirmed web research.", mutations: [], channel: widget_output }
  session_new: { description: "Control-plane new session command.", mutations: [], channel: widget_output }
  session_abort_current: { description: "Control-plane abort current session command.", mutations: [], channel: widget_output }
  session_status: { description: "Control-plane status command.", mutations: [], channel: widget_output }
  session_history: { description: "Control-plane history command.", mutations: [], channel: widget_output }
  session_resume: { description: "Control-plane resume command.", mutations: [], channel: widget_output }
  session_help: { description: "Control-plane help command.", mutations: [], channel: widget_output }
  select_repo_target:
    description: "Select standalone or existing-repo target."
    mutations: [{ op: MSet, path: repo.target_kind, from_arg: target_kind }]
    channel: widget_output
  authorize_standalone_target:
    description: "Authorize standalone repo writes after target selection."
    mutations:
      - { op: MSet, path: repo.write_authorized, value: true }
      - { op: MSet, path: repo.wiring_manifest.status, value: not_required }
    channel: widget_output
  load_wiring_manifest:
    description: "Load and validate fixed .pgas/wiring.yml for existing-repo writes."
    mutations:
      - { op: MSet, path: repo.wiring_manifest.status, from_arg: status }
      - { op: MSet, path: repo.wiring_manifest.path, from_arg: path }
      - { op: MSet, path: repo.blocked, from_arg: blocked }
    channel: widget_output
  authorize_existing_repo_target:
    description: "Authorize existing-repo writes after fixed manifest validation."
    mutations:
      - { op: MSet, path: repo.write_authorized, value: true }
    channel: widget_output
  create_curator_request:
    description: "Prepare a repo curator request."
    mutations: [{ op: MSet, path: repo.curator_request_lodged, value: true }]
    channel: widget_output
  design_architecture:
    description: "Mark architecture ready."
    mutations: [{ op: MSet, path: program.architecture_ready, value: true }]
    channel: widget_output
  plan_artifacts: { description: "Plan artifacts.", mutations: [{ op: MSet, path: artifact_plan.status, value: draft }], channel: widget_output }
  approve_artifact_plan:
    description: "Approve artifact plan after write authorization."
    mutations:
      - { op: MSet, path: artifact_plan.approved, value: true }
      - { op: MSet, path: artifact_plan.write_authorized, value: true }
    channel: widget_output
  write_scaffold_artifacts: { description: "Write planned artifacts.", mutations: [{ op: MSet, path: artifacts.written, value: true }], channel: widget_output }
  git_status: { description: "Read git status.", mutations: [], channel: widget_output }
  npm_install: { description: "Install dependencies.", mutations: [], channel: widget_output }
  npm_typecheck: { description: "Run typecheck.", mutations: [], channel: widget_output }
  npm_test: { description: "Run tests.", mutations: [], channel: widget_output }
  run_static_verification:
    description: "Record static verification evidence."
    mutations:
      - { op: MSet, path: graduation.static_verification, from_arg: status }
      - { op: MSet, path: graduation.static_evidence_id, from_arg: evidence_id }
    channel: widget_output
  run_api_blackbox_verification: { description: "Run black-box API verification.", mutations: [], channel: widget_output }
  run_live_provider_verification:
    description: "Record live provider verification evidence."
    mutations:
      - { op: MSet, path: graduation.live_verification, from_arg: status }
      - { op: MSet, path: graduation.live_evidence_id, from_arg: evidence_id }
    channel: widget_output
  git_rebase_latest:
    description: "Rebase on latest target repo state and record rebase status."
    mutations:
      - { op: MSet, path: graduation.rebase_status, from_arg: status }
      - { op: MSet, path: graduation.rebase_evidence_id, from_arg: evidence_id }
    channel: widget_output
  run_rebase_static_verification:
    description: "Record post-rebase static verification evidence."
    mutations:
      - { op: MSet, path: graduation.rebase_verification, from_arg: status }
      - { op: MSet, path: graduation.rebase_static_evidence_id, from_arg: evidence_id }
    channel: widget_output
  open_pull_request: { description: "Open pull request.", mutations: [], channel: widget_output }

schema:
  intake.mandate: string
  notebook.entries: array
  notebook.pins: array
  repo.target_kind: string
  repo.blocked: boolean
  repo.write_authorized: boolean
  repo.curator_request_lodged: boolean
  repo.wiring_manifest.status: string
  repo.wiring_manifest.path: string
  repo.required_facilities_missing: array
  program.runtime: string
  program.slug: string
  program.architecture_ready: boolean
  artifact_plan.status: string
  artifact_plan.approved: boolean
  artifact_plan.write_authorized: boolean
  artifacts.written: boolean
  artifacts.generated_paths: array
  graduation.static_verification: string
  graduation.static_evidence_id: string
  graduation.live_verification: string
  graduation.live_provider_intent: boolean
  graduation.live_evidence_id: string
  graduation.rebase_status: string
  graduation.rebase_evidence_id: string
  graduation.rebase_verification: string
  graduation.rebase_static_evidence_id: string
  governance.round_counter: number

repair_bound: 2

fallback:
  channel: widget_output
  payload: { ok: false }

guidance: {}

control_plane:
  version: 1
  session:
    program: "{{SLUG}}"
    binding: identity_channel_program
    concurrency:
      policy: single_active
      on_busy: reject_with_status
  free_text:
    control: ask
    bind:
      query: "$text"
  controls:
{{CONTROL_PLANE_CONTROLS_YAML}}
