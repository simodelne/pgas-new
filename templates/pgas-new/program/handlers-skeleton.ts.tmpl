import type { ToolHandler } from '@simodelne/pgas-server/plugin.js';
import { resolveDomainValue, type HandlerPayload } from './handlers/_resolver.js';

// The synthesizer emits this template as a handler directory:
// - handlers/index.ts
// - handlers/_resolver.ts

export const handlers: Record<string, ToolHandler> = {
  async begin_work(payload) {
    return {
      kind: 'work_started',
      payload,
    };
  },

  async record_user_note(payload) {
    const note = resolveDomainValue<string>(payload as HandlerPayload, 'note', '');
    return {
      kind: 'note_recorded',
      note,
    };
  },

  async example_action(payload) {
    return {
      kind: 'example_completed',
      payload,
    };
  },
};
