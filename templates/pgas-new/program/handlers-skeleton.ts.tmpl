import type { ToolHandler } from '@simodelne/pgas-server/plugin.js';

// The synthesizer emits this template as a handler directory:
// - handlers/index.ts
// - handlers/_resolver.ts

export interface HandlerPayload {
  domain?: Record<string, unknown>;
  args?: Record<string, unknown>;
  [key: string]: unknown;
}

export function resolveDomainValue<T>(
  payload: HandlerPayload,
  key: string,
  fallback?: T,
): T | undefined {
  if (payload.args && Object.prototype.hasOwnProperty.call(payload.args, key)) {
    return payload.args[key] as T;
  }
  if (payload.domain && Object.prototype.hasOwnProperty.call(payload.domain, key)) {
    return payload.domain[key] as T;
  }
  return fallback;
}

export const handlers: Record<string, ToolHandler> = {
  async begin_work(payload) {
    return {
      kind: 'work_started',
      payload,
    };
  },

  async record_user_note(payload) {
    const note = resolveDomainValue<string>(payload as HandlerPayload, 'note', '');
    return {
      kind: 'note_recorded',
      note,
    };
  },

  async example_action(payload) {
    return {
      kind: 'example_completed',
      payload,
    };
  },
};
