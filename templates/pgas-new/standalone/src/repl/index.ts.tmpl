import { connectNotifications, triggerStream } from '@simodelne/pgas-server/client.js';
import { intro, outro, text, isCancel } from '@clack/prompts';
import { renderAction, renderWidget, renderModeChange, renderError, type ReplState } from './renderer.js';

const PGAS_API_BASE = process.env.PGAS_API_BASE ?? 'http://localhost:3000';
const PGAS_WS_BASE = process.env.PGAS_WS_BASE ?? 'ws://localhost:3000';
const PROGRAM = '{{SLUG}}';

const state: ReplState = {
  sessionId: null,
  mode: null,
  running: true,
};

intro('{{NAME}} REPL');

// Connect to WebSocket notification stream for lifecycle events
const ws = connectNotifications(PGAS_WS_BASE, {
  onModeChange(newMode: string) {
    state.mode = newMode;
    renderModeChange(newMode);
  },
  onError(msg: string) {
    renderError(msg);
  },
  onClose() {
    state.running = false;
  },
});

async function trigger(channel: string, payload: unknown): Promise<void> {
  const stream = triggerStream(PGAS_API_BASE, {
    program: PROGRAM,
    sessionId: state.sessionId ?? undefined,
    channel,
    payload,
  });

  for await (const event of stream) {
    if (event.type === 'session_start') {
      state.sessionId = event.sessionId;
    } else if (event.type === 'action') {
      renderAction(event.result);
    } else if (event.type === 'widget') {
      await renderWidget(event.widget, trigger);
    }
  }
}

// Main REPL loop
while (state.running) {
  const input = await text({
    message: `${state.mode ?? PROGRAM} >`,
    placeholder: 'Type a message or /quit to exit',
  });

  if (isCancel(input) || input === '/quit') {
    break;
  }

  if (typeof input === 'string' && input.trim().length > 0) {
    await trigger('user_text', input.trim());
  }
}

ws.close();
outro('Session ended.');
