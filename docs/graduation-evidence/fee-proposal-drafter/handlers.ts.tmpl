import type { ReactionHandler, ToolHandler } from '@simodelne/pgas-server/plugin.js';
import { resolveDomainValue, type HandlerPayload } from './handlers/_resolver.js';

// Fee Proposal Drafter — graduation evidence with FILLED per-stage handlers.
//
// Generated by pgas-new from the approved stage topology, then filled with real,
// self-contained fee-proposal domain logic to exemplify production quality. Each
// handler reads accumulated domain state from prior stages (via resolveDomainValue
// over the engine domain snapshot) and computes the stage's real output. State is
// recorded by the action_map `from_arg` mutations in specs.yml; these handlers
// compute the `result_json` / `items_json` artifacts that ride the stage action.
//
// No external services are required — fee math, rate-card application, and
// document assembly are pure computation, so nothing here is a stub.

// --- Domain types -----------------------------------------------------------

type Complexity = 'simple' | 'standard' | 'complex';
type Role = 'partner' | 'senior_associate' | 'associate' | 'paralegal';

interface Scope {
  matter: string;
  complexity: Complexity;
  phases: string[];
  deliverables: string[];
}

interface RateCard {
  currency: string;
  rates: Record<Role, number>;
  jurisdiction_multiplier: number;
}

interface EffortLine {
  phase: string;
  role: Role;
  hours: number;
}

interface FeeModel {
  currency: string;
  hours_total: number;
  hourly_total: number;
  fixed_quote: number;
  capped_quote: number;
  blended_rate: number;
}

// --- Static reference data --------------------------------------------------

const BASE_RATES: Record<Role, number> = {
  partner: 850,
  senior_associate: 550,
  associate: 380,
  paralegal: 180,
};

// Hours per phase by complexity, distributed across roles. Honest illustrative
// weights — a production deployment would source these from historical matters.
const PHASE_HOURS: Record<Complexity, number> = { simple: 8, standard: 20, complex: 44 };
const ROLE_MIX: Record<Role, number> = {
  partner: 0.15,
  senior_associate: 0.3,
  associate: 0.4,
  paralegal: 0.15,
};
const CAPPED_PREMIUM = 0.15; // capped quote = hourly + 15% ceiling buffer

// --- Helpers ----------------------------------------------------------------

function round2(n: number): number {
  return Math.round(n * 100) / 100;
}

function parseStage<T>(payload: HandlerPayload, path: string, fallback: T): T {
  const raw = resolveDomainValue<string>(payload, path, '');
  if (!raw) return fallback;
  try {
    return JSON.parse(raw) as T;
  } catch {
    return fallback;
  }
}

function classifyComplexity(request: string): Complexity {
  const text = request.toLowerCase();
  if (/(cross-border|litigation|m&a|merger|regulatory|multi-jurisdiction)/.test(text)) return 'complex';
  if (/(advisory|review|drafting|negotiation|diligence)/.test(text)) return 'standard';
  return 'simple';
}

// --- Handlers ---------------------------------------------------------------

export const handlers: Record<string, ToolHandler> = {
  async begin_work(payload) {
    return { kind: 'work_started', payload };
  },

  async record_user_note(payload) {
    const note = resolveDomainValue<string>(payload as HandlerPayload, 'note', '');
    return { kind: 'note_recorded', note };
  },

  async complete_scope_analysis(payload) {
    const p = payload as HandlerPayload;
    const request =
      resolveDomainValue<string>(p, 'request', undefined) ??
      resolveDomainValue<string>(p, 'inputs.user_text', '') ??
      '';
    const complexity = classifyComplexity(request);
    const phases =
      complexity === 'complex'
        ? ['intake', 'diligence', 'analysis', 'negotiation', 'closing']
        : complexity === 'standard'
          ? ['intake', 'analysis', 'drafting', 'delivery']
          : ['intake', 'delivery'];
    const deliverables =
      complexity === 'complex'
        ? ['scoping memo', 'diligence report', 'transaction documents', 'closing checklist']
        : ['engagement letter', 'work product', 'final report'];
    const scope: Scope = { matter: request.slice(0, 200) || 'unspecified engagement', complexity, phases, deliverables };
    return {
      kind: 'scope_analyzed',
      result_json: JSON.stringify(scope),
      items_json: JSON.stringify(deliverables),
      summary: `Classified as ${complexity} (${phases.length} phases, ${deliverables.length} deliverables).`,
    };
  },

  async complete_rate_card_lookup(payload) {
    const p = payload as HandlerPayload;
    const scope = parseStage<Scope>(p, 'scope_analysis.result_json', {
      matter: '',
      complexity: 'standard',
      phases: [],
      deliverables: [],
    });
    // Complex matters carry a seniority-weighted jurisdiction premium.
    const jurisdiction_multiplier = scope.complexity === 'complex' ? 1.2 : scope.complexity === 'standard' ? 1.0 : 0.9;
    const rates = Object.fromEntries(
      (Object.keys(BASE_RATES) as Role[]).map((role) => [role, round2(BASE_RATES[role] * jurisdiction_multiplier)]),
    ) as Record<Role, number>;
    const card: RateCard = { currency: 'USD', rates, jurisdiction_multiplier };
    return {
      kind: 'rate_card_loaded',
      result_json: JSON.stringify(card),
      items_json: JSON.stringify(Object.entries(rates).map(([role, rate]) => `${role}: $${rate}/h`)),
      summary: `Rate card at ${jurisdiction_multiplier}x for ${scope.complexity} matter.`,
    };
  },

  async complete_effort_estimation(payload) {
    const p = payload as HandlerPayload;
    const scope = parseStage<Scope>(p, 'scope_analysis.result_json', {
      matter: '',
      complexity: 'standard',
      phases: ['intake', 'delivery'],
      deliverables: [],
    });
    const perPhase = PHASE_HOURS[scope.complexity];
    const lines: EffortLine[] = [];
    for (const phase of scope.phases) {
      for (const role of Object.keys(ROLE_MIX) as Role[]) {
        const hours = round2(perPhase * ROLE_MIX[role]);
        if (hours > 0) lines.push({ phase, role, hours });
      }
    }
    const hours_total = round2(lines.reduce((sum, l) => sum + l.hours, 0));
    return {
      kind: 'effort_estimated',
      result_json: JSON.stringify({ lines, hours_total }),
      items_json: JSON.stringify(lines.map((l) => `${l.phase}/${l.role}: ${l.hours}h`)),
      summary: `${hours_total}h across ${scope.phases.length} phases.`,
    };
  },

  async complete_fee_modeling(payload) {
    const p = payload as HandlerPayload;
    const card = parseStage<RateCard>(p, 'rate_card_lookup.result_json', {
      currency: 'USD',
      rates: BASE_RATES,
      jurisdiction_multiplier: 1,
    });
    const effort = parseStage<{ lines: EffortLine[]; hours_total: number }>(p, 'effort_estimation.result_json', {
      lines: [],
      hours_total: 0,
    });
    const hourly_total = round2(effort.lines.reduce((sum, l) => sum + l.hours * (card.rates[l.role] ?? 0), 0));
    const blended_rate = effort.hours_total > 0 ? round2(hourly_total / effort.hours_total) : 0;
    const model: FeeModel = {
      currency: card.currency,
      hours_total: effort.hours_total,
      hourly_total,
      fixed_quote: round2(hourly_total), // fixed = expected hourly total
      capped_quote: round2(hourly_total * (1 + CAPPED_PREMIUM)),
      blended_rate,
    };
    return {
      kind: 'fee_modeled',
      result_json: JSON.stringify(model),
      items_json: JSON.stringify([
        `hourly: $${model.hourly_total}`,
        `fixed: $${model.fixed_quote}`,
        `capped: $${model.capped_quote}`,
        `blended: $${model.blended_rate}/h`,
      ]),
      summary: `Hourly $${model.hourly_total}; blended $${model.blended_rate}/h.`,
    };
  },

  async complete_risk_adjustment(payload) {
    const p = payload as HandlerPayload;
    const model = parseStage<FeeModel>(p, 'fee_modeling.result_json', {
      currency: 'USD',
      hours_total: 0,
      hourly_total: 0,
      fixed_quote: 0,
      capped_quote: 0,
      blended_rate: 0,
    });
    const urgent = Boolean(resolveDomainValue<boolean>(p, 'urgent', false));
    const novel = Boolean(resolveDomainValue<boolean>(p, 'novel', false));
    const premium = (urgent ? 0.1 : 0) + (novel ? 0.08 : 0);
    const adjusted = {
      ...model,
      risk_premium_pct: round2(premium * 100),
      fixed_quote: round2(model.fixed_quote * (1 + premium)),
      capped_quote: round2(model.capped_quote * (1 + premium)),
    };
    return {
      kind: 'risk_adjusted',
      result_json: JSON.stringify(adjusted),
      items_json: JSON.stringify([`risk premium: ${adjusted.risk_premium_pct}%`, `adjusted fixed: $${adjusted.fixed_quote}`]),
      summary: `Applied ${adjusted.risk_premium_pct}% risk premium.`,
    };
  },

  async complete_draft_assembly(payload) {
    const p = payload as HandlerPayload;
    const scope = parseStage<Scope>(p, 'scope_analysis.result_json', {
      matter: 'engagement',
      complexity: 'standard',
      phases: [],
      deliverables: [],
    });
    const fees = parseStage<FeeModel & { risk_premium_pct?: number }>(p, 'risk_adjustment.result_json', {
      currency: 'USD',
      hours_total: 0,
      hourly_total: 0,
      fixed_quote: 0,
      capped_quote: 0,
      blended_rate: 0,
    });
    const doc = [
      `# Fee Proposal — ${scope.matter}`,
      ``,
      `## Scope (${scope.complexity})`,
      ...scope.deliverables.map((d) => `- ${d}`),
      ``,
      `## Fees (${fees.currency})`,
      `- Estimated hours: ${fees.hours_total}`,
      `- Fixed quote: $${fees.fixed_quote}`,
      `- Capped quote: $${fees.capped_quote}`,
      `- Blended rate: $${fees.blended_rate}/h`,
      ...(fees.risk_premium_pct ? [`- Risk premium applied: ${fees.risk_premium_pct}%`] : []),
      ``,
      `## Assumptions`,
      `- Scope and effort per the analysis above; changes re-quoted.`,
      `## Terms`,
      `- Fees exclusive of disbursements and taxes. Invoiced monthly.`,
    ].join('\n');
    return {
      kind: 'draft_assembled',
      result_json: JSON.stringify({ document_markdown: doc, sections: ['scope', 'fees', 'assumptions', 'terms'] }),
      items_json: JSON.stringify(['scope', 'fees', 'assumptions', 'terms']),
      summary: `Assembled proposal (${doc.length} chars).`,
    };
  },

  async advance_partner_review_to_revision(payload) {
    const p = payload as HandlerPayload;
    const comments = resolveDomainValue<string>(p, 'comments', 'Revisions requested by reviewing partner.');
    return {
      kind: 'partner_review_changes_requested',
      result_json: JSON.stringify({ decision: 'changes_requested', comments }),
      items_json: JSON.stringify([comments]),
      summary: 'Partner requested revisions.',
    };
  },

  async advance_partner_review_to_client_delivery(payload) {
    const p = payload as HandlerPayload;
    const approver = resolveDomainValue<string>(p, 'approver', 'reviewing partner');
    return {
      kind: 'partner_review_approved',
      result_json: JSON.stringify({ decision: 'approved', approver }),
      items_json: JSON.stringify([`approved by ${approver}`]),
      summary: `Approved for client delivery by ${approver}.`,
    };
  },

  async complete_revision(payload) {
    const p = payload as HandlerPayload;
    const model = parseStage<FeeModel>(p, 'risk_adjustment.result_json', {
      currency: 'USD',
      hours_total: 0,
      hourly_total: 0,
      fixed_quote: 0,
      capped_quote: 0,
      blended_rate: 0,
    });
    const discountPct = Number(resolveDomainValue<number>(p, 'discount_pct', 0) ?? 0);
    const revised = {
      ...model,
      fixed_quote: round2(model.fixed_quote * (1 - discountPct / 100)),
      capped_quote: round2(model.capped_quote * (1 - discountPct / 100)),
      revision_discount_pct: discountPct,
    };
    return {
      kind: 'revision_completed',
      result_json: JSON.stringify(revised),
      items_json: JSON.stringify([`revised fixed: $${revised.fixed_quote}`, `discount: ${discountPct}%`]),
      summary: `Applied ${discountPct}% revision discount.`,
    };
  },
};

// No foundry-driven reactions for this evidence program.
export const reactionHandlers: Map<string, ReactionHandler> = new Map();
