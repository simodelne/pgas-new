name: fee-proposal-drafter
termination: BoundedSession
topology: CyclicTopology
pure: true
preamble: |-
  Program: Fee Proposal Drafter. Draft elaborate client fee proposals for simoneos: capture the engagement request, analyze scope, load the applicable rate card, estimate effort, build a fee model, apply risk adjustments, assemble the proposal document, route it through partner review with a revision loop, and deliver a client-ready proposal.

  This spec was synthesized mechanically by pgas-new.
initial: request_intake
terminal:
  - client_delivery
features:
  - base
  - runtime_control
channels:
  user_text:
    direction: In
    sync: Async
  system_mode_entry:
    direction: In
    sync: Async
  widget_output:
    direction: Out
    sync: Async
modes:
  request_intake:
    vocabulary:
      - begin_work
      - record_user_note
      - session_new
      - session_abort_current
      - session_status
      - session_history
      - session_resume
      - session_help
    channels:
      - user_text
      - system_mode_entry
      - widget_output
    transitions:
      - target: scope_analysis
        guard:
          kind: FieldTruthy
          path: request.captured
  scope_analysis:
    vocabulary:
      - complete_scope_analysis
      - record_user_note
      - session_new
      - session_abort_current
      - session_status
      - session_history
      - session_resume
      - session_help
    channels:
      - user_text
      - widget_output
    transitions:
      - target: rate_card_lookup
        guard:
          kind: FieldTruthy
          path: scope.analyzed
  rate_card_lookup:
    vocabulary:
      - complete_rate_card_lookup
      - record_user_note
      - session_new
      - session_abort_current
      - session_status
      - session_history
      - session_resume
      - session_help
    channels:
      - user_text
      - widget_output
    transitions:
      - target: effort_estimation
        guard:
          kind: FieldTruthy
          path: rates.loaded
  effort_estimation:
    vocabulary:
      - complete_effort_estimation
      - record_user_note
      - session_new
      - session_abort_current
      - session_status
      - session_history
      - session_resume
      - session_help
    channels:
      - user_text
      - widget_output
    transitions:
      - target: fee_modeling
        guard:
          kind: FieldTruthy
          path: effort.estimated
  fee_modeling:
    vocabulary:
      - complete_fee_modeling
      - record_user_note
      - session_new
      - session_abort_current
      - session_status
      - session_history
      - session_resume
      - session_help
    channels:
      - user_text
      - widget_output
    transitions:
      - target: risk_adjustment
        guard:
          kind: FieldTruthy
          path: fee.modeled
  risk_adjustment:
    vocabulary:
      - complete_risk_adjustment
      - record_user_note
      - session_new
      - session_abort_current
      - session_status
      - session_history
      - session_resume
      - session_help
    channels:
      - user_text
      - widget_output
    transitions:
      - target: draft_assembly
        guard:
          kind: FieldTruthy
          path: risk.adjusted
  draft_assembly:
    vocabulary:
      - complete_draft_assembly
      - record_user_note
      - session_new
      - session_abort_current
      - session_status
      - session_history
      - session_resume
      - session_help
    channels:
      - user_text
      - widget_output
    transitions:
      - target: partner_review
        guard:
          kind: FieldTruthy
          path: draft.assembled
  partner_review:
    vocabulary:
      - advance_partner_review_to_revision
      - advance_partner_review_to_client_delivery
      - record_user_note
      - session_new
      - session_abort_current
      - session_status
      - session_history
      - session_resume
      - session_help
    channels:
      - user_text
      - widget_output
    transitions:
      - target: revision
        guard:
          kind: FieldTruthy
          path: review.changes_requested
      - target: client_delivery
        guard:
          kind: FieldTruthy
          path: delivery.sent
  revision:
    vocabulary:
      - complete_revision
      - record_user_note
      - session_new
      - session_abort_current
      - session_status
      - session_history
      - session_resume
      - session_help
    channels:
      - user_text
      - widget_output
    transitions:
      - target: partner_review
        guard:
          kind: FieldTruthy
          path: revision.completed
  client_delivery:
    vocabulary:
      - session_status
      - session_history
      - session_help
    channels:
      - widget_output
    transitions: []
proceed_to:
  begin_work: scope_analysis
  complete_scope_analysis: rate_card_lookup
  complete_rate_card_lookup: effort_estimation
  complete_effort_estimation: fee_modeling
  complete_fee_modeling: risk_adjustment
  complete_risk_adjustment: draft_assembly
  complete_draft_assembly: partner_review
  advance_partner_review_to_revision: revision
  advance_partner_review_to_client_delivery: client_delivery
  complete_revision: partner_review
projection:
  request_intake:
    include:
      - inputs.user_text
      - notebook.entries
      - notebook.pins
      - request_intake.started
      - request.captured
    exclude: []
  client_delivery:
    include:
      - scope.analyzed
      - rates.loaded
      - effort.estimated
      - fee.modeled
      - risk.adjusted
      - draft.assembled
      - review.changes_requested
      - delivery.sent
      - revision.completed
      - scope_analysis.result_json
      - scope_analysis.items_json
      - rate_card_lookup.result_json
      - rate_card_lookup.items_json
      - effort_estimation.result_json
      - effort_estimation.items_json
      - fee_modeling.result_json
      - fee_modeling.items_json
      - risk_adjustment.result_json
      - risk_adjustment.items_json
      - draft_assembly.result_json
      - draft_assembly.items_json
      - partner_review.result_json
      - partner_review.items_json
      - revision.result_json
      - revision.items_json
    exclude: []
  scope_analysis:
    include:
      - inputs.user_text
      - notebook.entries
      - notebook.pins
      - scope.analyzed
      - scope_analysis.result_json
      - scope_analysis.items_json
    exclude: []
  rate_card_lookup:
    include:
      - inputs.user_text
      - notebook.entries
      - notebook.pins
      - rates.loaded
      - rate_card_lookup.result_json
      - rate_card_lookup.items_json
    exclude: []
  effort_estimation:
    include:
      - inputs.user_text
      - notebook.entries
      - notebook.pins
      - effort.estimated
      - effort_estimation.result_json
      - effort_estimation.items_json
    exclude: []
  fee_modeling:
    include:
      - inputs.user_text
      - notebook.entries
      - notebook.pins
      - fee.modeled
      - fee_modeling.result_json
      - fee_modeling.items_json
    exclude: []
  risk_adjustment:
    include:
      - inputs.user_text
      - notebook.entries
      - notebook.pins
      - risk.adjusted
      - risk_adjustment.result_json
      - risk_adjustment.items_json
    exclude: []
  draft_assembly:
    include:
      - inputs.user_text
      - notebook.entries
      - notebook.pins
      - draft.assembled
      - draft_assembly.result_json
      - draft_assembly.items_json
    exclude: []
  partner_review:
    include:
      - inputs.user_text
      - notebook.entries
      - notebook.pins
      - review.changes_requested
      - delivery.sent
      - partner_review.result_json
      - partner_review.items_json
    exclude: []
  revision:
    include:
      - inputs.user_text
      - notebook.entries
      - notebook.pins
      - revision.completed
      - revision.result_json
      - revision.items_json
    exclude: []
prompts:
  request_intake: Capture the initial request for Fee Proposal Drafter and start the work.
  client_delivery: Terminal mode after Fee Proposal Drafter completion is confirmed.
  scope_analysis: Perform the scope_analysis stage for Fee Proposal Drafter.
  rate_card_lookup: Perform the rate_card_lookup stage for Fee Proposal Drafter.
  effort_estimation: Perform the effort_estimation stage for Fee Proposal Drafter.
  fee_modeling: Perform the fee_modeling stage for Fee Proposal Drafter.
  risk_adjustment: Perform the risk_adjustment stage for Fee Proposal Drafter.
  draft_assembly: Perform the draft_assembly stage for Fee Proposal Drafter.
  partner_review: Perform the partner_review stage for Fee Proposal Drafter.
  revision: Perform the revision stage for Fee Proposal Drafter.
ingestion:
  user_text:
    - inputs.user_text
  system_mode_entry:
    - inputs.mode_entry
action_map:
  begin_work:
    description: Start request_intake and advance exactly one hop to scope_analysis.
    mutations:
      - op: MSet
        path: request.captured
        value: true
    channel: widget_output
  record_user_note:
    description: Record a notebook note.
    mutations:
      - op: MAppend
        path: notebook.entries
        from_arg: note
    channel: widget_output
  session_new:
    description: Control-plane new session command.
    mutations: []
    channel: widget_output
  session_abort_current:
