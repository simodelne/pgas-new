schema:
  inputs.user_text: string
  inputs.query_result.kind: string
  inputs.query_result.value_json: object
  inputs.query_meta.source_path: string
  inputs.query_meta.source_channel: string
  inputs.query_meta.continuation_round: number
  inputs.query_meta.scope_redirect: string
  inputs.query_meta.message: string
  inputs.mode_entry: object
  inputs.mode_entry.mode: string
  inputs.mode_entry.from_mode: string
  inputs.mode_entry.entry_round: number
  governance.round_counter: number
  notebook.entries: array
  notebook.pins: array
  request_intake.started: boolean
  request.captured: boolean
  scope.analyzed: boolean
  rates.loaded: boolean
  effort.estimated: boolean
  fee.modeled: boolean
  risk.adjusted: boolean
  draft.assembled: boolean
  review.changes_requested: boolean
  delivery.sent: boolean
  revision.completed: boolean
  scope_analysis.result_json: string
  scope_analysis.items_json: string
  rate_card_lookup.result_json: string
  rate_card_lookup.items_json: string
  effort_estimation.result_json: string
  effort_estimation.items_json: string
  fee_modeling.result_json: string
  fee_modeling.items_json: string
  risk_adjustment.result_json: string
  risk_adjustment.items_json: string
  draft_assembly.result_json: string
  draft_assembly.items_json: string
  partner_review.result_json: string
  partner_review.items_json: string
  revision.result_json: string
  revision.items_json: string
repair_bound: 2
fallback:
  channel: widget_output
  payload:
    ok: false
guidance:
  scope_analysis:
    - Use the synthesized JSON-string scalar fields for structured handler results.
  rate_card_lookup:
    - Use the synthesized JSON-string scalar fields for structured handler results.
  effort_estimation:
    - Use the synthesized JSON-string scalar fields for structured handler results.
  fee_modeling:
    - Use the synthesized JSON-string scalar fields for structured handler results.
  risk_adjustment:
    - Use the synthesized JSON-string scalar fields for structured handler results.
  draft_assembly:
    - Use the synthesized JSON-string scalar fields for structured handler results.
  partner_review:
    - Use the synthesized JSON-string scalar fields for structured handler results.
  revision:
    - Use the synthesized JSON-string scalar fields for structured handler results.
control_plane:
  version: 1
  session:
    program: fee-proposal-drafter
    binding: identity_channel_program
    concurrency:
      policy: single_active
      on_busy: reject_with_status
  free_text:
    control: ask
    bind:
      query: $text
  controls:
    ask:
      title: Ask
      aliases:
        - /ask
      args:
        query:
          type: string
          required: true
          capture: rest
      dispatch:
        - op: create_session
          as: session
          program: fee-proposal-drafter
          domain_context:
            query: $args.query
        - op: trigger
          session: $session.id
          channel: user_text
          payload: $args.query
          mode: async
    abort:
      title: Abort run
      aliases:
        - /abort
        - /stop
      availability:
        when: active_session.running
      dispatch:
        - op: abort_session
          session: $active_session.id
      presentation:
        priority: destructive
        confirm: true
    new:
      title: New session
      aliases:
        - /new
        - /reset
        - /restart
      dispatch:
        - op: create_session
          as: session
          program: fee-proposal-drafter
      presentation:
        priority: secondary
    history:
      title: Recent sessions
      aliases:
        - /history
        - /recent
      dispatch:
        - op: list_sessions
          as: sessions
      presentation:
        priority: secondary
    status:
      title: Status
      aliases:
        - /status
      availability:
        when: active_session
      dispatch:
        - op: render_session
          session: $active_session.id
          view: status
      presentation:
        priority: contextual
    resume:
      title: Resume
      aliases:
        - /resume
      availability:
        when: active_session
      dispatch:
        - op: send_runtime_control
          session: $active_session.id
          control: resume
      presentation:
        priority: contextual
    help:
      title: Help
      aliases:
        - /help
      dispatch:
        - op: render_help
      presentation:
        priority: secondary
